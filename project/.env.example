# OpenAI (AI blueprint generation). If unset, the app falls back to a sample blueprint.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=45000
OPENAI_JSON_MAX_TOKENS=1400
OPENAI_TEXT_MAX_TOKENS=2200
# Optional: custom base URL (e.g. Azure OpenAI proxy)
# OPENAI_BASE_URL=

# Supabase (persistent project and job storage).
# If unset, development uses project/.local/*.json.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Anonymous sessions are enabled by default when Supabase is configured.
BUILDPIXIES_ENABLE_ANON_AUTH=1
NEXT_PUBLIC_BUILDPIXIES_ENABLE_ANON_AUTH=1

# Hosted deployments should require persistent Supabase storage.
BUILDPIXIES_REQUIRE_SUPABASE=0
# Optional: disable the development JSON fallback.
BUILDPIXIES_DISABLE_FILE_STORE=0
