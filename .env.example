# OpenAI (AI blueprint generation). If unset, the app falls back to a sample blueprint.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional: custom base URL (e.g. Azure OpenAI proxy)
# OPENAI_BASE_URL=

# Supabase (project storage + pgvector memory). If unset, an in-memory store is used.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=  # server-only, for privileged operations
