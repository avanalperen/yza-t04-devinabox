# OpenRouter Free (preferred AI provider). If unset, OpenAI is tried next;
# if neither key exists, the app uses deterministic sample outputs.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=BuildPixies
# Optional public app URL used for OpenRouter attribution.
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_TIMEOUT_MS=90000
# Retries transient 429/5xx responses while respecting Retry-After.
OPENROUTER_MAX_RETRIES=4
OPENROUTER_JSON_MAX_TOKENS=1400
OPENROUTER_TEXT_MAX_TOKENS=2200
# Secure default is 0: only providers that deny prompt data collection.
OPENROUTER_ALLOW_DATA_COLLECTION=0

# Optional OpenAI fallback. OpenRouter takes precedence when both keys exist.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=45000
OPENAI_MAX_RETRIES=2
OPENAI_JSON_MAX_TOKENS=1400
OPENAI_TEXT_MAX_TOKENS=2200
# Optional: custom OpenAI-compatible base URL.
# OPENAI_BASE_URL=

# Supabase (persistent project and job storage).
# If unset, development uses .local/*.json.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Required for durable generation workers; never expose publicly.
SUPABASE_SERVICE_ROLE_KEY=

# Anonymous sessions are enabled by default when Supabase is configured.
BUILDPIXIES_ENABLE_ANON_AUTH=1
NEXT_PUBLIC_BUILDPIXIES_ENABLE_ANON_AUTH=1

# Hosted deployments should require persistent Supabase storage.
BUILDPIXIES_REQUIRE_SUPABASE=0
# Vercel enables its durable queue automatically. Set to 1 for `next dev` queue tests.
BUILDPIXIES_USE_VERCEL_QUEUE=0
# Optional: disable the development JSON fallback.
BUILDPIXIES_DISABLE_FILE_STORE=0
